import numpy as np
import matplotlib.pyplot as plt
from matplotlib.patches import Circle
import scipy
import time


#constants
#Coord system = cartesian is Z=height, x=radial, y = tangential relative to hub, spherical is radial from robot to goal
vi = 10 #m/s
phi_i = 60 *3.1415/180 #deg -> rad
theta_i = 0 *3.14159/180 # deg -> rad
m = 0.475 /2.205 #lb -> kg  [0.448 - 0.5]
ball_Diam = 5.91 *(1/12/3.281) #in -> m
ball_radius = ball_Diam/2
x_Area = 3.14159 * ball_radius**2 #cross sectional area
rho = 1.225 #kg/m^3
xi= 0 #m
zi = 14 *(1/12/3.281) #in -> m
zf = 72 *(1/12/3.281) #in -> m
x_goal = 20 /3.281 #ft -> m
x_goal_radius = 24 * 1/12/3.281 #in to m
# x_goal_max = 12 *(1/12/3.281) #in -> m
# x_goal_min = 20 *(1/12/3.281) #in -> m
# y_goal_left = 21 *(1/12/3.281) #in -> m
# y_goal_right = 21 *(1/12/3.281) #in -> m
Cd = 0.47 #drag coeff sphere in 10^4 - 10^5 reynolds num
g = -9.81 #m/s^2
dt = 10**-4

#error values in std using ranges (assumed to be gaussian)
err_vi = vi * 0.067/3 #range of intial velocity ~10%
err_theta = 0.01 * 3.14159/180/3  #deg -> rad
err_phi = 2 * 3.14159/180/3  #deg -> rad


start = time.perf_counter()
N = 5000
dt = np.array([1e-3 for i in range(N)]) #s
rng = np.random.default_rng(488)
t = 0
z=[zi for i in range(N)]
x=0
y=0
vi = rng.normal(loc = vi, scale = err_vi, size=N)
phi = rng.normal(loc = phi_i, scale = err_phi, size=N)
phi_initial = list(phi * 57.3) # rad->deg
theta = rng.normal(loc = theta_i, scale = err_vi, size=N)
v_x = vi *np.cos(phi)*np.cos(theta)
v_z = vi * np.sin(phi)
v_y = vi * np.cos(phi) * np.sin(theta)
v = np.sqrt(v_x**2 + v_z**2 + v_y**2)
phi = phi_i

alive = np.ones(N, dtype = bool)

while (max(z) > zf or  max(v_z) >0) or max(z)<=0:
    accel_x = -Cd * rho * x_Area * v ** 2 * np.cos(phi) * np.cos(theta) / m
    accel_y = -Cd * rho * x_Area * v ** 2 * np.cos(phi) * np.sin(theta) / m
    accel_z = g - Cd*rho*x_Area*v**2*np.sin(phi)/m
    v_x += accel_x * dt
    v_z += accel_z * dt
    v_y += accel_y * dt
    v = np.sqrt(v_x**2 + v_z**2 + v_y**2)
    phi = np.arctan(v_z/np.sqrt(v_x**2+v_y**2))
    theta = np.arctan(v_y/v_x)
    z += v_z * dt
    x += v_x * dt
    y += v_y * dt
    t += dt

    hit = alive & (((z <= zf) & (v_z <= 0)) | (z<= 0))


    dt[hit] = 0

if max(z)<0:
    print(f"for dt = {dt} there was no solution found")


end = time.perf_counter()
print((end-start))

print(f"For Phi_initial mean = {np.mean(phi_initial)} and std = {np.std(phi_initial)}")
print(f"For Theta mean = {np.mean(theta)} and std = {np.std(theta)}")
print(f"For V_initial mean = {np.mean(vi)} and std = {np.std(vi)}")
print(f"For Distance mean = {np.mean(x)} and std = {np.std(x)}")

score = np.sqrt((x_goal-x)**2) < x_goal_radius
print(f"you scored {100*np.count_nonzero(score)/np.size(score,0)}%")


plt.figure()
plt.tricontourf(vi,phi_initial,x)
plt.colorbar(label="distance")
plt.xlabel("initial velocity")
plt.ylabel("intial phi")
plt.scatter(vi, phi_initial, s=1, c="k")

fig, ax = plt.subplots()
ax.scatter(x, y)
circ = Circle((x_goal, 0), x_goal_radius, fill=False, linewidth=2, edgecolor = 'red')  # add edgecolor=... if you want
ax.add_patch(circ)
ax.set_aspect('equal', adjustable='box')  # makes it look like a true circle
plt.show()


plt.show()